electrons.source2.num_particles_per_cell_each_dim = 150
electrons.source2.do_continuous_injection = 0
electrons.source2.profile = constant
electrons.source2.density = 5.4e20
electrons.source2.momentum_distribution_type = maxwell_boltzmann
electrons.source2.theta_distribution_type = constant
# 无量纲粒子温度，计算方式：theta = k_B * T(K) / m / c / c
