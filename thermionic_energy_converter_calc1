# 算例介绍
# 本算例用于模拟铯热离子能量转换器，基于warpX官网Pierce Diode at the Child–Langmuir Limit算例修改而来
# 原算例介绍详见：https://github.com/BLAST-WarpX/warpx/tree/development/Examples/Physics_applications/pierce_diode
# 首先修改为真空热离子能量转换器并进行验证，真空热离子能量转换器物理模型见文献：空间核动力（苏著亭）——已完成
# 真空热离子能量转换器验证计算文件如 thermionicVacuum 所示，配套后处理文件为 plot_sim_thermionic.py
# 相比 thermionicVacuum 计算，thermionicCesium-dsmc 添加了多种粒子，包括：
# 1. 中性基态铯原子，2. 9种中性激发态铯原子， 3. 一种带 +1 电荷的铯离子
# 暂时考虑101种碰撞过程，考虑了9种激发态每种的碰撞过程
# 基态粒子：1弹性碰撞+9激发碰撞+1电离碰撞=11种
# 激发态粒子：9激发碰撞+1电离碰撞=10种
# 总计：1*11 + 9*10 = 101种碰撞过程

# author
authors = Haocheng Zhao

# constants
my_constants.electron_mass = 9.11e-31 # [kg] Using electron mass
my_constants.relative_atomic_mass = 1.661e-27   # [kg] Using the relative atomic mass
my_constants.c = 299792458          # [m/s]
my_constants.kB = 1. / 11605        # [eV/K]
my_constants.kB_u = 1.380649e-23    # [J/K]
my_constants.torr = 133.322368      # [Pa]
my_constants.ideal_gas_constant = 8.314  # [J/(mol·K)]
my_constants.NA = 6.02214076e23
my_constants.cesium_atoms_mass = 132.91 * relative_atomic_mass
# NOTE: Voltage is now POSITIVE to accelerate negative electrons
my_constants.temperature_emitter = 1700 + 273.15  # [K] 1700 C in Kelvin -- 1973.15K
my_constants.temperature_collector = 523 + 273.15  # [K] 523 C in Kelvin -- 796.15K
my_constants.temperature_cesium = 300 + 273.15  # [K] 300 C in Kelvin -- 573.15K
# pressure and other parameters of cesium vapor
my_constants.pressure_cesium = 0.323 * torr  # [Pa] pressure of cesium vapor -- 66.66Pa
my_constants.temperature_cesium_vapor = 0.5 * (temperature_emitter + temperature_collector)  # [K] temperature of cesium vapor 1384.75K
my_constants.density_cesium_atoms = pressure_cesium / (ideal_gas_constant * temperature_cesium_vapor) * NA  # [m^-3] density of cesium atoms) -- 2.2527e21 m^-3
# work function of the emitter (tungsten with cesium coating)
my_constants.log_temperature = log(temperature_emitter / temperature_cesium) 
my_constants.workfunction_emitter = (1.948 - 2.877 * log_temperature + 1.419 * log_temperature**2) / (1-1.264*log_temperature+0.485*log_temperature**2) # -- 3.1352 V
my_constants.devide_temperature = temperature_collector / temperature_cesium
my_constants.workfunction_collector = 1.1173 + 2.0169 * devide_temperature - 1.7643 * devide_temperature **2 + 0.4405 * devide_temperature**3 # -- 1.6953 V
# voltage is negative to attract electrons
my_constants.voltage_anode_cathod = 1.19 # [V] anode to cathode voltage
my_constants.voltage_out = workfunction_emitter - workfunction_collector - voltage_anode_cathod # -- 1.4399 - voltage_anode_cathod
my_constants.voltage_emitter = -workfunction_emitter
my_constants.voltage_collector = voltage_emitter + voltage_anode_cathod
my_constants.gap = 0.5e-3  # [m] gap between emitter and collector
my_constants.nz = 12000 # dz = 4.1667e-8 m，对 n_e = 1e21 m^-3 仍满足更保守的德拜长度分辨率。
my_constants.dz = gap/nz
# other key parameters
my_constants.cm2 = 1e-4
my_constants.cm3 = 1e-6
my_constants.q_e = 1.60217662e-19
my_constants.A = 12e5  # [A/m^2/K^2] Richardson constant for tungsten with cesium coating
my_constants.current_emitter = A * (temperature_emitter**2)*exp(-workfunction_emitter/kB/temperature_emitter) # [A/m^2]
# 等离子体固有频率，用于计算单步时间步长
my_constants.omega = sqrt(5e20*1.6e-19*1.6e-19/8.854e-12/9.11e-31) # 1.2597e12
my_constants.dt = 2*3.1415926/omega * 0.01   # = 4.9810e-14 s，保持等离子体频率约束不变。
my_constants.ep0 = 8.8541878188e-12
# Recalculate current density at Child-Langmuir limit for electrons
my_constants.J_CL = ( (4 / 9)* ep0 * sqrt(2 * q_e / electron_mass) * abs(voltage_anode_cathod) ** (3 / 2) / gap**2 )
# 最大时间步
my_constants.max_step_sim = 50000

# 基础设置
warpx.do_electrostatic = labframe
# 时间步长
warpx.const_dt = dt
