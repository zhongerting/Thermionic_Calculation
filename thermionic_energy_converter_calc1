electrons.source1.injection_style = NFluxPerCell
electrons.source1.num_particles_per_cell = 3
electrons.source1.surface_flux_pos = 0.0
electrons.source1.flux_normal_axis = z
electrons.source1.flux_direction = 1
electrons.source1.flux_profile = constant
electrons.source1.flux = current_emitter / q_e
electrons.source1.momentum_distribution_type = gaussianflux
# 第二个为体源，用于初始化一开始的粒子
